generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Job {
    jobId          String       @id 
    status         String       @default("done")
    filePath       String       
    fileName       String
    extractedText  String
    wordCount      Int
    pageCount      Int
    metadata       Json
    processedAt    DateTime    @default(now())
}